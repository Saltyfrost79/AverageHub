local PlaceId = game.PlaceId
local BaseURL = "https://raw.githubusercontent.com/Saltyfrost79/AverageHub/main/"
local function notify(msg)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Average Hub",
        Text = msg,
        Duration = 5
    })
end

local Games = {
    [102438325176100] = "Anipixel.lua",
    [99248392277037] = "Umeleerng.lua",
}

if Games[PlaceId] then
    local fileName = Games[PlaceId]
    local success, scriptContent = pcall(function()
        return game:HttpGet(BaseURL .. fileName)
    end)

    if success then
        loadstring(scriptContent)()
    else
        notify("Failed to load script from GitHub.")
    end
else
    notify("No script supported for this game.")
end
